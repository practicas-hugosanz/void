# ----------------------------------------------------------------------
# CONFIGURACIÓN VOID - OPTIMIZADA PARA RAILWAY
# ----------------------------------------------------------------------

# 1. Seguridad básica y archivos de entrada
Options -Indexes
DirectoryIndex index.php index.html

RewriteEngine On

# 2. FORZAR HTTPS Y CORREGIR CABECERAS (Arregla el error Mixed Content)
# Esto le dice a Apache que confíe en el proxy de Railway para el SSL
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 3. ELIMINAR DOBLES BARRAS (Arregla el error //api/auth.php)
# Limpia la URL para que las cookies de sesión se envíen siempre bien
RewriteCond %{THE_REQUEST} //
RewriteRule .* /$0 [R=301,L]

# 4. QUITAR EXTENSIÓN .PHP PARA HUMANOS
# Permite entrar a /admin en lugar de /admin.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L,QSA]

# 5. SEGURIDAD: Bloquear acceso a archivos sensibles
<FilesMatch "\.(sqlite|db|log)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>
